#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

log_info "Deleting all VCF and kubectl contexts"
echo ""

# Step 1: List existing contexts
log_step "Listing existing contexts..."
echo ""

# List VCF contexts
log_info "VCF Contexts:"
VCF_CONTEXTS=$(vcf context list 2>/dev/null | tail -n +2 || echo "")
if [[ -z "$VCF_CONTEXTS" ]]; then
    log_info "  (None found)"
else
    echo "$VCF_CONTEXTS" | awk '{print "  " $0}'
fi

echo ""

# List kubectl contexts
log_info "kubectl Contexts:"
KUBECTL_CONTEXTS=$(kubectl config get-contexts --no-headers 2>/dev/null || echo "")
if [[ -z "$KUBECTL_CONTEXTS" ]]; then
    log_info "  (None found)"
else
    echo "$KUBECTL_CONTEXTS" | awk '{print "  " $0}'
fi

echo ""

# Step 2: Confirmation
log_warn "WARNING: This will delete ALL VCF and kubectl contexts"
log_warn "This includes:"
log_warn "  - Supervisor context: ${SUPERVISOR_CONTEXT}:${SUPERVISOR_NAMESPACE_NAME}"
log_warn "  - VKS cluster context: ${CLUSTER_CONTEXT}:${CLUSTER_NAME}"
log_warn "  - Any other VCF/kubectl contexts"
log_warn ""
log_warn "This will also delete any VKS cluster resources if they exist"
echo ""

read -p "Are you sure you want to delete ALL contexts? (yes/no): " -r confirm

if [[ ! "$confirm" =~ ^yes$ ]]; then
    log_info "Deletion cancelled"
    exit 0
fi

echo ""

# Step 3: Optional - Delete VKS cluster if it exists
log_step "Checking for VKS cluster to delete..."

# Verify Supervisor context is available
if kubectl get ns &>/dev/null; then
    if kubectl get cluster "$CLUSTER_NAME" &>/dev/null; then
        log_warn "VKS cluster found: $CLUSTER_NAME"
        read -p "Also delete the VKS cluster? (yes/no): " -r delete_cluster
        
        if [[ "$delete_cluster" =~ ^yes$ ]]; then
            log_step "Deleting VKS cluster: $CLUSTER_NAME..."
            if kubectl delete cluster "$CLUSTER_NAME" 2>/dev/null; then
                log_info "✓ Delete command sent for cluster: $CLUSTER_NAME"
                log_warn "Cluster deletion is in progress (5-10 minutes)"
                log_info "You can monitor deletion separately or wait"
            else
                log_warn "Could not delete VKS cluster: $CLUSTER_NAME"
            fi
            echo ""
        fi
    else
        log_info "No VKS cluster found: $CLUSTER_NAME"
    fi
else
    log_info "Supervisor context not available - skipping cluster deletion check"
fi

echo ""

# Step 4: Delete VCF contexts
log_step "Deleting VCF contexts..."

if [[ ! -z "$VCF_CONTEXTS" ]]; then
    DELETED_VCF=0
    while IFS= read -r line; do
        if [[ ! -z "$line" ]]; then
            # Extract context name (first column)
            CONTEXT_NAME=$(echo "$line" | awk '{print $1}')
            if [[ ! -z "$CONTEXT_NAME" ]]; then
                if vcf context delete "$CONTEXT_NAME" -y 2>/dev/null; then
                    log_info "✓ Deleted VCF context: $CONTEXT_NAME"
                    ((DELETED_VCF++))
                else
                    log_warn "Could not delete VCF context: $CONTEXT_NAME"
                fi
            fi
        fi
    done <<< "$VCF_CONTEXTS"
    
    if [[ $DELETED_VCF -gt 0 ]]; then
        log_info "Total VCF contexts deleted: $DELETED_VCF"
    fi
else
    log_info "No VCF contexts to delete"
fi

echo ""

# Step 5: Delete kubectl contexts
log_step "Deleting kubectl contexts..."

if [[ ! -z "$KUBECTL_CONTEXTS" ]]; then
    DELETED_KUBECTL=0
    while IFS= read -r line; do
        if [[ ! -z "$line" ]]; then
            # Extract context name (first column, but skip if it's marked as CURRENT with asterisk)
            CONTEXT_NAME=$(echo "$line" | awk '{print $1}' | sed 's/*//g')
            if [[ ! -z "$CONTEXT_NAME" && "$CONTEXT_NAME" != "CURRENT" ]]; then
                if kubectl config delete-context "$CONTEXT_NAME" 2>/dev/null; then
                    log_info "✓ Deleted kubectl context: $CONTEXT_NAME"
                    ((DELETED_KUBECTL++))
                else
                    log_warn "Could not delete kubectl context: $CONTEXT_NAME"
                fi
            fi
        fi
    done <<< "$KUBECTL_CONTEXTS"
    
    if [[ $DELETED_KUBECTL -gt 0 ]]; then
        log_info "Total kubectl contexts deleted: $DELETED_KUBECTL"
    fi
else
    log_info "No kubectl contexts to delete"
fi

echo ""

# Step 6: Verify deletion
log_step "Verifying context deletion..."
echo ""

REMAINING_VCF=$(vcf context list 2>/dev/null | tail -n +2 | wc -l)
REMAINING_KUBECTL=$(kubectl config get-contexts --no-headers 2>/dev/null | wc -l)

if [[ $REMAINING_VCF -eq 0 ]]; then
    log_info "✓ All VCF contexts deleted"
else
    log_warn "⚠ $REMAINING_VCF VCF context(s) remaining"
fi

if [[ $REMAINING_KUBECTL -eq 0 ]]; then
    log_info "✓ All kubectl contexts deleted"
else
    log_warn "⚠ $REMAINING_KUBECTL kubectl context(s) remaining"
fi

echo ""

# Step 7: Reset kubeconfig if needed
log_step "Cleaning up kubeconfig..."

# Try to unset current context if none remain
if [[ $REMAINING_KUBECTL -eq 0 ]]; then
    if kubectl config current-context &>/dev/null; then
        log_warn "Current context is set but no contexts remain - kubeconfig may be in inconsistent state"
        log_info "You may need to manually clean ~/.kube/config"
    fi
fi

echo ""
log_info "Context deletion complete!"
echo ""
log_info "To re-establish connections, run:"
echo "  ./ns1-login                 # Connect to Supervisor"
echo "  ./ns1-login-vks1            # Connect to VKS cluster (if cluster exists)"
