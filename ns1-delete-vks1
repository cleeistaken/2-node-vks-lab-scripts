#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Verify we're logged into the Supervisor (not in VKS cluster context)
verify_supervisor_context() {
    if ! kubectl get ns &>/dev/null; then
        log_error "Not connected to Supervisor. Please run 'ns1-login' first."
        exit 1
    fi
    
    # Check if we're accidentally in the VKS cluster context
    CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "")
    if [[ "$CURRENT_CONTEXT" == *"$CLUSTER_NAME"* ]] || [[ "$CURRENT_CONTEXT" == "$CLUSTER_CONTEXT:$CLUSTER_NAME" ]]; then
        log_warn "You are currently in the VKS cluster context: $CURRENT_CONTEXT"
        log_error "This script must be run from the Supervisor context"
        log_info "Please run: ./ns1-login"
        log_info "Then run: ./vks1-delete"
        exit 1
    fi
}

log_info "Deleting VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify we're in the right context
log_step "Verifying Supervisor context..."
verify_supervisor_context
log_info "Supervisor context verified"

echo ""

# Step 2: Check if cluster exists
log_step "Checking if VKS cluster exists..."
if ! kubectl get cluster "$CLUSTER_NAME" &>/dev/null; then
    log_error "VKS cluster '$CLUSTER_NAME' not found"
    exit 1
fi
log_info "VKS cluster found"

echo ""

# Step 3: Confirm deletion
log_warn "WARNING: You are about to delete the VKS cluster: $CLUSTER_NAME"
log_warn "This action cannot be undone."
echo ""
read -p "Are you sure you want to delete this cluster? (yes/no): " -r confirm

if [[ ! "$confirm" =~ ^yes$ ]]; then
    log_info "Deletion cancelled"
    exit 0
fi

echo ""

# Step 4: Delete the cluster
log_step "Deleting VKS cluster: $CLUSTER_NAME..."
if kubectl delete cluster "$CLUSTER_NAME"; then
    log_info "Delete command sent successfully"
else
    log_error "Failed to delete VKS cluster"
    exit 1
fi

echo ""

# Step 5: Monitor deletion
log_step "Monitoring VKS cluster deletion..."
log_warn "VKS cluster deletion may take 5-10 minutes"
echo "Press Ctrl+C to stop monitoring"
echo ""

# Monitor until cluster is gone
while kubectl get cluster "$CLUSTER_NAME" &>/dev/null; do
    echo -n "."
    sleep 5
done

echo ""
log_info "VKS Cluster deleted successfully: $CLUSTER_NAME"

echo ""

# Step 6: Clean up VKS cluster context
log_step "Cleaning up VKS cluster contexts..."

# Delete the cluster-specific context from kubectl config
VKS_CONTEXT="${CLUSTER_CONTEXT}:${CLUSTER_NAME}"
if kubectl config get-contexts "$VKS_CONTEXT" &>/dev/null; then
    if kubectl config delete-context "$VKS_CONTEXT" &>/dev/null; then
        log_info "✓ Kubectl context deleted: $VKS_CONTEXT"
    else
        log_warn "Could not delete kubectl context: $VKS_CONTEXT"
    fi
else
    log_info "Kubectl context not found: $VKS_CONTEXT"
fi

# Delete the VCF context for the VKS cluster
if vcf context list 2>/dev/null | grep -q "^${CLUSTER_CONTEXT}:${CLUSTER_NAME}"; then
    if vcf context delete "${CLUSTER_CONTEXT}:${CLUSTER_NAME}" -y 2>/dev/null; then
        log_info "✓ VCF context deleted: ${CLUSTER_CONTEXT}:${CLUSTER_NAME}"
    else
        log_warn "Could not delete VCF context: ${CLUSTER_CONTEXT}:${CLUSTER_NAME}"
    fi
else
    log_info "VCF context not found: ${CLUSTER_CONTEXT}:${CLUSTER_NAME}"
fi

echo ""
log_info "VKS cluster deletion complete!"

