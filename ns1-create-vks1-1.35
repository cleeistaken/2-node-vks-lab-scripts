#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Verify we're logged into the Supervisor (not in VKS cluster context)
verify_supervisor_context() {
    if ! kubectl get ns &>/dev/null; then
        log_error "Not connected to Supervisor. Please run 'ns1-login' first."
        exit 1
    fi
    
    # Check if we're accidentally in the VKS cluster context
    CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "")
    if [[ "$CURRENT_CONTEXT" == *"$CLUSTER_NAME"* ]] || [[ "$CURRENT_CONTEXT" == "$CLUSTER_CONTEXT:$CLUSTER_NAME" ]]; then
        log_warn "You are currently in the VKS cluster context: $CURRENT_CONTEXT"
        log_error "This script must be run from the Supervisor context"
        log_info "Please run: ./ns1-login"
        log_info "Then run: ./vks1-create-1.35"
        exit 1
    fi
}

# Check if cluster is ready for upgrade (validates AddonsReconciled condition)
validate_cluster_upgrade_readiness() {
    local cluster_name="$1"
    local max_wait=300  # 5 minutes maximum wait
    local check_interval=10  # Check every 10 seconds
    local elapsed=0
    
    log_step "Validating cluster readiness for upgrade..."
    
    while [[ $elapsed -lt $max_wait ]]; do
        # Check if AddonsReconciled condition is True
        ADDONS_READY=$(kubectl get cluster "$cluster_name" \
            -o jsonpath='{.status.conditions[?(@.type=="AddonsReconciled")].status}' 2>/dev/null || echo "")
        
        if [[ "$ADDONS_READY" == "True" ]]; then
            log_info "Cluster is ready for upgrade (AddonsReconciled: True)"
            return 0
        fi
        
        # Get more detailed status for user feedback
        AVAILABLE=$(kubectl get cluster "$cluster_name" \
            -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null || echo "Unknown")
        ADDONS_MSG=$(kubectl get cluster "$cluster_name" \
            -o jsonpath='{.status.conditions[?(@.type=="AddonsReconciled")].message}' 2>/dev/null || echo "Initializing...")
        
        if [[ $elapsed -eq 0 ]]; then
            log_warn "Cluster addons not yet reconciled. Waiting for cluster stabilization..."
            echo "  Current status: Ready=$AVAILABLE, AddonsReconciled=$ADDONS_READY"
        fi
        
        if [[ $((elapsed % 30)) -eq 0 && $elapsed -gt 0 ]]; then
            echo "  [$elapsed/$max_wait seconds] Waiting for addons to reconcile..."
        fi
        
        sleep $check_interval
        ((elapsed += check_interval))
    done
    
    # Timeout reached
    echo ""
    log_error "Cluster did not reach AddonsReconciled=True within $max_wait seconds"
    log_warn "The cluster may have addon issues preventing upgrade."
    echo ""
    log_step "Current cluster status:"
    kubectl get cluster "$cluster_name" || true
    echo ""
    log_step "Cluster conditions:"
    kubectl get cluster "$cluster_name" -o jsonpath='{.status.conditions[*]}' | grep -o '"type":"[^"]*","status":"[^"]*"' | tr ',' '\n' || true
    echo ""
    log_error "To diagnose the issue, run:"
    log_error "  kubectl describe cluster $cluster_name"
    log_error "  kubectl get clusters $cluster_name -o yaml"
    echo ""
    return 1
}

# Check if cluster already exists and determine if this is an upgrade or downgrade
check_cluster_exists() {
    if kubectl get clusters "$CLUSTER_NAME" &>/dev/null; then
        log_info "Existing cluster found: $CLUSTER_NAME"
        
        # Get current cluster class version from existing cluster
        CURRENT_CLASS=$(kubectl get cluster "$CLUSTER_NAME" -o jsonpath='{.spec.topology.classRef.name}' 2>/dev/null || echo "")
        CURRENT_VERSION=$(kubectl get cluster "$CLUSTER_NAME" -o jsonpath='{.spec.topology.version}' 2>/dev/null || echo "")
        
        if [[ -z "$CURRENT_CLASS" ]]; then
            # Fallback to older API (v1beta1)
            CURRENT_CLASS=$(kubectl get cluster "$CLUSTER_NAME" -o jsonpath='{.spec.topology.class}' 2>/dev/null || echo "")
        fi
        
        if [[ ! -z "$CURRENT_CLASS" && ! -z "$CURRENT_VERSION" ]]; then
            echo ""
            
            # Extract version numbers for comparison (v1.33, v1.34, v1.35)
            CURRENT_MAJOR=$(echo "$CURRENT_VERSION" | cut -d. -f1-2)
            TARGET_VERSION="v1.35"
            
            # Check for downgrade scenario
            if [[ "$CURRENT_VERSION" != "$TARGET_VERSION" ]]; then
                # Extract just the major.minor version (v1.35 from v1.35.2+vmware.1)
                # Compare versions: v1.33=133, v1.34=134, v1.35=135
                # Remove 'v' prefix and everything after second dot
                CURRENT_MAJOR=$(echo "$CURRENT_VERSION" | grep -o '^v[0-9]*\.[0-9]*' | sed 's/v//' | tr -d '.')
                TARGET_NUM=$(echo "$TARGET_VERSION" | sed 's/v//' | tr -d '.')
                
                # Use 0 as default if we couldn't extract version
                CURRENT_NUM=${CURRENT_MAJOR:-0}
                
                if [[ ! -z "$CURRENT_NUM" && "$CURRENT_NUM" -gt "$TARGET_NUM" ]]; then
                    # Downgrade detected
                    echo ""
                    log_error "DOWNGRADE NOT SUPPORTED"
                    log_error "Current cluster version: $CURRENT_VERSION"
                    log_error "Target version: $TARGET_VERSION"
                    log_error "Downgrading clusters is not supported and may cause data loss."
                    log_error "To use an older version, delete this cluster and create a new one."
                    echo ""
                    log_error "To delete the cluster, run: ./vks1-delete"
                    echo ""
                    exit 1
                fi
            fi
            
            # This is either same version or upgrade
            log_warn "UPGRADE SCENARIO DETECTED"
            log_info "Current cluster class: $CURRENT_CLASS (version: $CURRENT_VERSION)"
            log_info "Target cluster class: builtin-generic-v3.6.0 (version: v1.35)"
            echo ""
            
            # Check for unsupported upgrade path (1.33 to 1.35 directly)
            if [[ "$CURRENT_NUM" == "133" && "$TARGET_NUM" == "135" ]]; then
                echo ""
                log_error "UNSUPPORTED UPGRADE PATH"
                log_error "Direct upgrade from v1.33 to v1.35 is not supported"
                log_error "Current cluster version: $CURRENT_VERSION"
                log_error "Target version: v1.35"
                log_error ""
                log_warn "You must upgrade through the intermediate version (v1.34)"
                log_warn "Upgrade path: v1.33 → v1.34 → v1.35"
                echo ""
                log_info "Step 1: Upgrade to v1.34"
                log_info "  ./ns1-create-vks1-1.34"
                echo ""
                log_info "Step 2: After v1.34 is stable, upgrade to v1.35"
                log_info "  ./ns1-create-vks1-1.35"
                echo ""
                exit 1
            fi
            
            return 0
        fi
        return 1
    fi
    return 1
}

# Create VKS cluster manifest
create_vks_manifest() {
    local manifest_file="$1"
    
    cat > "$manifest_file" <<EOL
apiVersion: cluster.x-k8s.io/v1beta2
kind: Cluster
metadata:
  name: $CLUSTER_NAME
spec:
  clusterNetwork:
    services:
      cidrBlocks: ["$CLUSTER_SERVICES_CIDR"]
    pods:
      cidrBlocks: ["$CLUSTER_PODS_CIDR"]
    serviceDomain: "$CLUSTER_SERVICE_DOMAIN"
  topology:
    classRef:
      name: builtin-generic-v3.6.0
    version: v1.35
    controlPlane:
      replicas: $CLUSTER_CONTROL_PLANE_REPLICAS
    workers:
      machineDeployments:
      - class: node-pool
        name: node-pool-1
        replicas: $CLUSTER_WORKER_REPLICAS
        variables:
          overrides:
          - name: vmClass
            value: $CLUSTER_VM_CLASS_WORKER
          - name: volumes
            value:
            - capacity: $STORAGE_SIZE
              mountPath: $STORAGE_MOUNT_PATH
              name: containerd
              storageClass: $CLUSTER_STORAGE_CLASS
    variables:
    - name: vmClass
      value: $CLUSTER_VM_CLASS_CONTROL_PLANE
    - name: storageClass
      value: $CLUSTER_STORAGE_CLASS
    - name: vsphereOptions
      value:
        persistentVolumes:
          defaultStorageClass: $CLUSTER_STORAGE_CLASS
    - name: kubernetes
      value:
        security:
          podSecurityStandard:
            enforce: baseline
EOL
}

log_info "Creating VKS Cluster: $CLUSTER_NAME (Kubernetes v1.35 with builtin-generic-v3.6.0)"
echo ""

# Step 1: Verify we're in the right context
log_step "Verifying Supervisor context..."
verify_supervisor_context
log_info "Supervisor context verified"

echo ""

# Step 2: Check if cluster exists and determine if upgrade
IS_UPGRADE=false
if check_cluster_exists; then
    IS_UPGRADE=true
    echo ""
    # Validate cluster is ready for upgrade before proceeding
    if ! validate_cluster_upgrade_readiness "$CLUSTER_NAME"; then
        log_error "Cluster is not ready for upgrade. Please wait and try again."
        exit 1
    fi
    log_step "Applying cluster upgrade manifest..."
else
    log_step "Creating new VKS cluster..."
fi

# Step 3: Create the manifest
log_step "Creating VKS cluster manifest file..."
MANIFEST_FILE="vks.yaml"
create_vks_manifest "$MANIFEST_FILE"
log_info "Manifest created: $MANIFEST_FILE"

# Show manifest summary
log_info "Manifest configuration:"
echo "  - Cluster Name: $CLUSTER_NAME"
echo "  - Kubernetes Version: v1.35"
echo "  - Cluster Class: builtin-generic-v3.6.0"
echo "  - Control Plane Replicas: $CLUSTER_CONTROL_PLANE_REPLICAS"
echo "  - Worker Replicas: $CLUSTER_WORKER_REPLICAS"
echo "  - Worker VM Class: $CLUSTER_VM_CLASS_WORKER"
echo "  - Storage Class: $CLUSTER_STORAGE_CLASS"

echo ""

# Step 4: Apply the manifest
if [[ "$IS_UPGRADE" == "true" ]]; then
    log_step "Applying cluster upgrade..."
else
    log_step "Applying VKS cluster manifest..."
fi

if kubectl apply -f "$MANIFEST_FILE"; then
    if [[ "$IS_UPGRADE" == "true" ]]; then
        log_info "Cluster upgrade initiated successfully"
    else
        log_info "VKS cluster manifest applied successfully"
    fi
else
    log_error "Failed to apply VKS cluster manifest"
    exit 1
fi

echo ""

# Step 5: Monitor cluster creation/upgrade
if [[ "$IS_UPGRADE" == "true" ]]; then
    log_step "Monitoring cluster upgrade..."
else
    log_step "Monitoring VKS cluster creation..."
fi

# Cluster creation/upgrade monitoring with timeout
CREATION_TIMEOUT=${CLUSTER_CREATION_TIMEOUT:-900}  # Default 15 minutes
POLL_INTERVAL=5  # Check every 5 seconds
ELAPSED=0
READY=false

log_info "Timeout: $CREATION_TIMEOUT seconds (~$((CREATION_TIMEOUT/60)) minutes)"
echo ""

while [[ $ELAPSED -lt $CREATION_TIMEOUT ]]; do
    # Get cluster status using kubectl get clusters
    CLUSTER_STATUS=$(kubectl get clusters "$CLUSTER_NAME" 2>/dev/null)
    
    if [[ -z "$CLUSTER_STATUS" ]]; then
        if [[ "$IS_UPGRADE" == "true" ]]; then
            echo "[$(date '+%H:%M:%S')] Waiting for cluster upgrade to progress..."
        else
            echo "[$(date '+%H:%M:%S')] Waiting for cluster to be created..."
        fi
        sleep $POLL_INTERVAL
        ((ELAPSED += POLL_INTERVAL))
        continue
    fi
    
    # Extract AVAILABLE status from the kubectl output
    AVAILABLE_STATUS=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $3}')
    PHASE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $9}')
    CP_AVAILABLE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $5}')
    W_AVAILABLE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $7}')
    
    # Check if cluster is available
    if [[ "$AVAILABLE_STATUS" == "True" ]]; then
        READY=true
        break
    fi
    
    # Print status if still creating/upgrading
    if [[ "$IS_UPGRADE" == "true" ]]; then
        echo "[$(date '+%H:%M:%S')] Upgrading... | AVAILABLE: $AVAILABLE_STATUS | Phase: $PHASE | CP: $CP_AVAILABLE | Workers: $W_AVAILABLE | Elapsed: ${ELAPSED}s"
    else
        echo "[$(date '+%H:%M:%S')] Creating... | AVAILABLE: $AVAILABLE_STATUS | Phase: $PHASE | CP: $CP_AVAILABLE | Workers: $W_AVAILABLE | Elapsed: ${ELAPSED}s"
    fi
    
    # Wait before next check
    sleep $POLL_INTERVAL
    ((ELAPSED += POLL_INTERVAL))
done

echo ""

if [[ "$READY" == "true" ]]; then
    if [[ "$IS_UPGRADE" == "true" ]]; then
        log_info "VKS Cluster upgrade completed: $CLUSTER_NAME"
    else
        log_info "VKS Cluster is Ready: $CLUSTER_NAME"
    fi
    echo ""
    log_step "Final cluster status:"
    kubectl get clusters "$CLUSTER_NAME"
    echo ""
    log_info "You can now access the cluster with: ./vks1-login"
else
    if [[ "$IS_UPGRADE" == "true" ]]; then
        log_warn "VKS cluster upgrade timeout after $CREATION_TIMEOUT seconds"
    else
        log_warn "VKS cluster creation timeout after $CREATION_TIMEOUT seconds"
    fi
    echo ""
    log_step "Current cluster status:"
    kubectl get clusters "$CLUSTER_NAME"
    echo ""
    log_info "To check status later, run: kubectl get clusters $CLUSTER_NAME"
    log_info "To view cluster details, run: kubectl describe cluster $CLUSTER_NAME"
fi
