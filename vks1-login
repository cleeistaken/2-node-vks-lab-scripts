#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Create or refresh a Supervisor context
create_or_refresh_supervisor_context() {
    local context_name="$1"
    local endpoint="$2"
    local username="$3"
    local context_selector="$4"  # Format: "context:namespace" for vcf context use
    
    log_step "Creating context: $context_name"
    echo -e "${CYAN}When prompted, enter password:${NC} ${CYAN}$SUPERVISOR_PASSWORD${NC}"
    echo ""
    
    # Try to create the context - run directly to show prompts, use temp file for errors
    local error_file
    error_file=$(mktemp)
    
    vcf context create "$context_name" \
        --endpoint "$endpoint" \
        --username "$username" 2>"$error_file"
    local create_status=$?
    
    local create_error
    create_error=$(cat "$error_file")
    rm -f "$error_file"
    
    # Check if the error is "already exists"
    if [[ $create_status -ne 0 ]]; then
        if echo "$create_error" | grep -qi "already exists"; then
            echo ""
            log_info "Context already exists: $context_name"
            log_step "Refreshing context: $context_selector"
            
            # Refresh the specific context (no prompting)
            error_file=$(mktemp)
            vcf context refresh "$context_selector" 2>"$error_file"
            local refresh_status=$?
            local refresh_error=$(cat "$error_file")
            rm -f "$error_file"
            
            if [[ $refresh_status -eq 0 ]]; then
                log_info "Context refreshed successfully"
            else
                log_warn "Context refresh returned: $refresh_error"
            fi
        else
            echo ""
            log_error "Failed to create context: $create_error"
            return 1
        fi
    else
        echo ""
        log_info "Context created successfully"
    fi
    return 0
}

# Create or refresh a VKS cluster context
create_or_refresh_vks_context() {
    local context_name="$1"
    local endpoint="$2"
    local username="$3"
    local namespace_name="$4"
    local cluster_name="$5"
    local context_selector="$6"  # Format: "context:namespace" for vcf context use
    
    log_step "Creating context: $context_name"
    echo -e "${CYAN}When prompted, enter password:${NC} ${CYAN}$SUPERVISOR_PASSWORD${NC}"
    echo ""
    
    # Try to create the context - run directly to show prompts, use temp file for errors
    local error_file
    error_file=$(mktemp)
    
    vcf context create "$context_name" \
        --endpoint "$endpoint" \
        --username "$username" \
        --workload-cluster-namespace="$namespace_name" \
        --workload-cluster-name="$cluster_name" 2>"$error_file"
    local create_status=$?
    
    local create_error
    create_error=$(cat "$error_file")
    rm -f "$error_file"
    
    # Check if the error is "already exists"
    if [[ $create_status -ne 0 ]]; then
        if echo "$create_error" | grep -qi "already exists"; then
            echo ""
            log_info "Context already exists: $context_name"
            log_step "Refreshing context: $context_selector"
            
            # Refresh the specific context (no prompting)
            error_file=$(mktemp)
            vcf context refresh "$context_selector" 2>"$error_file"
            local refresh_status=$?
            local refresh_error=$(cat "$error_file")
            rm -f "$error_file"
            
            if [[ $refresh_status -eq 0 ]]; then
                log_info "Context refreshed successfully"
            else
                log_warn "Context refresh returned: $refresh_error"
            fi
        else
            echo ""
            log_error "Failed to create context: $create_error"
            return 1
        fi
    else
        echo ""
        log_info "Context created successfully"
    fi
    return 0
}

log_info "Logging into VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Create or refresh VKS Cluster Context
if ! create_or_refresh_vks_context "$CLUSTER_CONTEXT" "$SUPERVISOR_IP" "$SUPERVISOR_USERNAME" \
    "$SUPERVISOR_NAMESPACE_NAME" "$CLUSTER_NAME" "$CLUSTER_CONTEXT:$CLUSTER_NAME"; then
    exit 1
fi

echo ""

# Step 2: Select VKS Cluster Context (if not already selected by create_or_refresh_context)
log_step "Ensuring context is selected: $CLUSTER_CONTEXT:$CLUSTER_NAME"
if vcf context use "$CLUSTER_CONTEXT:$CLUSTER_NAME" 2>/dev/null; then
    log_info "VKS cluster context confirmed"
else
    log_error "Failed to select VKS cluster context"
    exit 1
fi

echo ""

# Step 3: Validate connection
log_step "Validating connection to VKS cluster..."
if kubectl get nodes > /dev/null 2>&1; then
    log_info "Connection validated successfully"
    echo ""
    log_step "VKS Cluster nodes:"
    kubectl get nodes
else
    log_error "Failed to validate connection to VKS cluster"
    exit 1
fi

echo ""
log_info "Successfully logged into VKS Cluster: $CLUSTER_NAME"
