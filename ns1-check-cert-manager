#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

log_info "Checking Cert-Manager Status on VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify Supervisor context is valid (not in VKS cluster context)
log_step "Verifying Supervisor context..."

CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "")
if [[ -z "$CURRENT_CONTEXT" ]]; then
    log_error "No valid kubectl context. Please run 'ns1-login' first."
    exit 1
fi

# Check if we're accidentally in the VKS cluster context
if [[ "$CURRENT_CONTEXT" == *"$CLUSTER_NAME"* ]] || [[ "$CURRENT_CONTEXT" == "$CLUSTER_CONTEXT:$CLUSTER_NAME" ]]; then
    log_warn "You are currently in the VKS cluster context: $CURRENT_CONTEXT"
    log_error "This script must be run from the Supervisor context"
    log_info "Please run: ./ns1-login"
    log_info "Then run: ./ns1-cert-manager-check"
    exit 1
fi
log_info "Current context: $CURRENT_CONTEXT"

# Step 2: Verify VKS cluster exists
log_step "Verifying VKS cluster exists..."
if ! kubectl get clusters "$CLUSTER_NAME" &>/dev/null; then
    log_error "VKS cluster '$CLUSTER_NAME' not found"
    exit 1
fi
log_info "VKS cluster verified: $CLUSTER_NAME"

echo ""

# Step 3: Check if cert-manager addon is installed
log_step "Checking cert-manager addon installation status..."
ADDON_STATUS=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep cert-manager || echo "")

if [[ -z "$ADDON_STATUS" ]]; then
    log_warn "Cert-manager addon is NOT installed"
    log_info "To install cert-manager, run: ./ns1-create-cert-manager"
    exit 0
fi

log_info "Cert-manager addon found"
echo ""
log_step "Addon status:"
echo "$ADDON_STATUS"
echo ""

# Step 4: Extract addon readiness status
ADDON_READY=$(echo "$ADDON_STATUS" | awk '{print $5}')
log_step "Addon readiness: $ADDON_READY"

if [[ "$ADDON_READY" != "True" ]]; then
    log_warn "Cert-manager addon is not fully ready yet"
    log_info "Current status: $ADDON_READY"
    log_info "Please check again in a moment"
fi

echo ""

# Step 5: Verify cert-manager pods in the cluster
log_step "Verifying cert-manager pods in the cluster..."

# Switch to VKS cluster context
if ! vcf context use "$CLUSTER_CONTEXT:$CLUSTER_NAME" 2>/dev/null; then
    log_warn "Could not switch to VKS cluster context for pod verification"
    log_warn "You can manually verify with: kubectl get all -n cert-manager"
    exit 0
fi

echo ""

CERT_MANAGER_PODS=$(kubectl get pods -n cert-manager 2>/dev/null || echo "")

if [[ -z "$CERT_MANAGER_PODS" ]]; then
    log_warn "Cert-manager namespace not found or no pods running"
    exit 0
fi

log_step "Cert-manager pods:"
kubectl get pods -n cert-manager
echo ""

# Check if all pods are running
RUNNING_PODS=$(kubectl get pods -n cert-manager --field-selector=status.phase=Running 2>/dev/null | tail -n +2 | wc -l)
TOTAL_PODS=$(kubectl get pods -n cert-manager 2>/dev/null | tail -n +2 | wc -l)

log_step "Pod status summary:"
log_info "Running pods: $RUNNING_PODS / $TOTAL_PODS"

if [[ $RUNNING_PODS -eq $TOTAL_PODS ]] && [[ $TOTAL_PODS -gt 0 ]]; then
    log_info "✓ All cert-manager pods are running and healthy"
else
    log_warn "⚠ Some cert-manager pods are not running"
fi

echo ""
log_step "Cert-manager services:"
kubectl get svc -n cert-manager

echo ""
log_info "Cert-manager check complete"
