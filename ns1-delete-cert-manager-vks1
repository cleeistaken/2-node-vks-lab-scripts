#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

log_info "Deleting Cert Manager from VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify Supervisor context is valid (not in VKS cluster context)
log_step "Verifying Supervisor context..."

CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "")
if [[ -z "$CURRENT_CONTEXT" ]]; then
    log_error "No valid kubectl context. Please run 'ns1-login' first."
    exit 1
fi

# Check if we're accidentally in the VKS cluster context
if [[ "$CURRENT_CONTEXT" == *"$CLUSTER_NAME"* ]] || [[ "$CURRENT_CONTEXT" == "$CLUSTER_CONTEXT:$CLUSTER_NAME" ]]; then
    log_warn "You are currently in the VKS cluster context: $CURRENT_CONTEXT"
    log_error "This script must be run from the Supervisor context"
    log_info "Please run: ./ns1-login"
    log_info "Then run: ./vks1-delete-cert-manager"
    exit 1
fi

echo ""

# Step 2: Verify VKS cluster exists
log_step "Verifying VKS cluster exists..."
if ! kubectl get clusters "$CLUSTER_NAME" &>/dev/null; then
    log_error "VKS cluster '$CLUSTER_NAME' not found."
    exit 1
fi
log_info "VKS cluster verified: $CLUSTER_NAME"

echo ""

# Step 3: Check if cert-manager addon is installed
log_step "Checking if cert-manager addon is installed..."
CERT_MANAGER_ADDON=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>&1 | grep cert-manager || echo "")

if [[ -z "$CERT_MANAGER_ADDON" ]]; then
    log_warn "Cert-manager addon is not installed on this cluster."
    log_info "Nothing to delete."
    exit 0
fi

log_info "Cert-manager addon found:"
echo "$CERT_MANAGER_ADDON"

echo ""

# Step 4: Confirm deletion
log_warn "WARNING: You are about to delete cert-manager from cluster: $CLUSTER_NAME"
log_warn "This will remove all cert-manager components and cannot be easily undone."
echo ""
read -p "Are you sure you want to delete cert-manager? (yes/no): " -r confirm

if [[ ! "$confirm" =~ ^[Yy][Ee][Ss]$ ]]; then
    log_info "Deletion cancelled"
    exit 0
fi

echo ""

# Step 5: Delete cert-manager addon
log_step "Deleting cert-manager addon..."
log_info "This may take a few minutes..."
echo ""

if vcf addon install delete cert-manager \
    --cluster-name "$CLUSTER_NAME" \
    -n "$SUPERVISOR_NAMESPACE_NAME" \
    -y 2>&1 | tee /tmp/cert-manager-delete.log; then
    
    log_info "Cert-manager deletion initiated"
else
    log_error "Failed to initiate cert-manager deletion"
    exit 1
fi

echo ""

# Step 6: Monitor deletion progress
log_step "Monitoring cert-manager deletion..."
DELETION_TIMEOUT=300  # 5 minutes
POLL_INTERVAL=5
ELAPSED=0
DELETED=false

log_info "Waiting for cert-manager addon to be deleted (timeout: ${DELETION_TIMEOUT}s)..."
echo ""

while [[ $ELAPSED -lt $DELETION_TIMEOUT ]]; do
    # Check addon status
    ADDON_STATUS=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep cert-manager || echo "")
    
    if [[ -z "$ADDON_STATUS" ]]; then
        DELETED=true
        break
    fi
    
    echo "[$(date '+%H:%M:%S')] Deletion in progress... | Elapsed: ${ELAPSED}s"
    
    sleep $POLL_INTERVAL
    ((ELAPSED += POLL_INTERVAL))
done

echo ""

if [[ "$DELETED" == "true" ]]; then
    log_info "Cert-manager addon has been successfully deleted"
    echo ""
    log_step "Verifying addon status:"
    FINAL_STATUS=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep cert-manager || echo "No cert-manager addon found")
    echo "$FINAL_STATUS"
    echo ""
    
    # Step 7: Verify deletion in the cluster
    log_step "Verifying cert-manager pods have been removed..."
    
    # Switch to VKS cluster context
    if vcf context use "$CLUSTER_CONTEXT:$CLUSTER_NAME" 2>/dev/null; then
        CERT_MANAGER_PODS=$(kubectl get pods -n cert-manager 2>/dev/null || echo "")
        
        if [[ -z "$CERT_MANAGER_PODS" ]] || [[ "$CERT_MANAGER_PODS" == *"No resources found"* ]]; then
            log_info "Cert-manager pods have been removed from the cluster"
        else
            log_warn "Some cert-manager pods may still exist:"
            kubectl get pods -n cert-manager || true
        fi
    else
        log_warn "Could not switch to VKS cluster context for verification"
    fi
else
    log_warn "Cert-manager deletion timeout after $DELETION_TIMEOUT seconds"
    echo ""
    log_step "Current addon status:"
    vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" | grep cert-manager || echo "Addon may be in deletion state"
    echo ""
    log_warn "Deletion may still be in progress. Check status later with:"
    echo "  vcf addon install list --cluster-name $CLUSTER_NAME -n $SUPERVISOR_NAMESPACE_NAME"
fi

echo ""
log_info "Deletion log saved to: /tmp/cert-manager-delete.log"
