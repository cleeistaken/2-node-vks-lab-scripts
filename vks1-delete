#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Verify we're logged into the Supervisor
verify_supervisor_context() {
    if ! kubectl get ns &>/dev/null; then
        log_error "Not connected to Supervisor. Please run 'login-ns1' first."
        exit 1
    fi
}

log_info "Deleting VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify we're in the right context
log_step "Verifying Supervisor context..."
verify_supervisor_context
log_info "Supervisor context verified"

echo ""

# Step 2: Check if cluster exists
log_step "Checking if VKS cluster exists..."
if ! kubectl get cluster "$CLUSTER_NAME" &>/dev/null; then
    log_error "VKS cluster '$CLUSTER_NAME' not found"
    exit 1
fi
log_info "VKS cluster found"

echo ""

# Step 3: Confirm deletion
log_warn "WARNING: You are about to delete the VKS cluster: $CLUSTER_NAME"
log_warn "This action cannot be undone."
echo ""
read -p "Are you sure you want to delete this cluster? (yes/no): " -r confirm

if [[ ! "$confirm" =~ ^yes$ ]]; then
    log_info "Deletion cancelled"
    exit 0
fi

echo ""

# Step 4: Delete the cluster
log_step "Deleting VKS cluster: $CLUSTER_NAME..."
if kubectl delete cluster "$CLUSTER_NAME"; then
    log_info "Delete command sent successfully"
else
    log_error "Failed to delete VKS cluster"
    exit 1
fi

echo ""

# Step 5: Monitor deletion
log_step "Monitoring VKS cluster deletion..."
log_warn "VKS cluster deletion may take 5-10 minutes"
echo "Press Ctrl+C to stop monitoring"
echo ""

# Monitor until cluster is gone
while kubectl get cluster "$CLUSTER_NAME" &>/dev/null; do
    echo -n "."
    sleep 5
done

echo ""
log_info "VKS Cluster deleted successfully: $CLUSTER_NAME"
