#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

log_info "Installing Cert Manager on VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify Supervisor context is valid (not in VKS cluster context)
log_step "Verifying Supervisor context..."

CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "")
if [[ -z "$CURRENT_CONTEXT" ]]; then
    log_error "No valid kubectl context. Please run 'ns1-login' first."
    exit 1
fi

# Check if we're accidentally in the VKS cluster context
if [[ "$CURRENT_CONTEXT" == *"$CLUSTER_NAME"* ]] || [[ "$CURRENT_CONTEXT" == "$CLUSTER_CONTEXT:$CLUSTER_NAME" ]]; then
    log_warn "You are currently in the VKS cluster context: $CURRENT_CONTEXT"
    log_error "This script must be run from the Supervisor context"
    log_info "Please run: ./ns1-login"
    log_info "Then run: ./vks1-install-cert-manager"
    exit 1
fi
log_info "Current context: $CURRENT_CONTEXT"

# Step 2: Verify VKS cluster exists
log_step "Verifying VKS cluster exists..."
if ! kubectl get clusters "$CLUSTER_NAME" &>/dev/null; then
    log_error "VKS cluster '$CLUSTER_NAME' not found. Create it with './create-vks1'"
    exit 1
fi

CLUSTER_AVAILABLE=$(kubectl get clusters "$CLUSTER_NAME" -o jsonpath='{.status.conditions[?(@.type=="Available")].status}' 2>/dev/null || echo "")
ADDONS_RECONCILED=$(kubectl get clusters "$CLUSTER_NAME" -o jsonpath='{.status.conditions[?(@.type=="AddonsReconciled")].status}' 2>/dev/null || echo "")

if [[ "$CLUSTER_AVAILABLE" != "True" || "$ADDONS_RECONCILED" != "True" ]]; then
    log_warn "VKS cluster is not fully ready"
    log_warn "  Available: $CLUSTER_AVAILABLE | AddonsReconciled: $ADDONS_RECONCILED"
    log_warn "Please wait for cluster to stabilize and try again"
    log_info "Check status with: ./ns1-check-vks1"
    exit 1
fi
log_info "✓ VKS cluster verified: $CLUSTER_NAME"

echo ""

# Step 3: Check if cert-manager is already installed
log_step "Checking if cert-manager is already installed..."
EXISTING_CERT_MANAGER=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep cert-manager || echo "")

if [[ ! -z "$EXISTING_CERT_MANAGER" ]]; then
    log_info "Cert-manager is already installed on cluster: $CLUSTER_NAME"
    echo ""
    log_step "Addon status:"
    echo "$EXISTING_CERT_MANAGER"
    echo ""
    log_info "To check detailed status, run: ./ns1-check-cert-manager"
    log_info "To remove cert-manager, run: ./ns1-delete-cert-manager-vks1"
    exit 0
fi

echo ""

# Step 4: List available cert-manager versions
log_step "Fetching available cert-manager versions..."
VERSIONS_OUTPUT=$(vcf addon available list cert-manager 2>&1 || echo "")

if [[ -z "$VERSIONS_OUTPUT" || "$VERSIONS_OUTPUT" == *"error"* ]]; then
    log_error "Failed to list available cert-manager versions."
    log_error "Make sure you are logged into the Supervisor with valid VCF credentials."
    exit 1
fi

# Extract the latest version and addon release name
# Format: NAMESPACE  ADDONNAME  VERSION  ADDON-RELEASE-NAME  PACKAGE
# We need both the VERSION (column 3) and ADDON-RELEASE-NAME (column 4) from the last data row
LATEST_VERSION=$(echo "$VERSIONS_OUTPUT" | awk 'NR>1 {version=$3; release=$4} END {print version}')
ADDON_RELEASE_NAME=$(echo "$VERSIONS_OUTPUT" | awk 'NR>1 {release=$4} END {print release}')

if [[ -z "$LATEST_VERSION" ]] || [[ -z "$ADDON_RELEASE_NAME" ]]; then
    log_error "Could not determine latest cert-manager version or addon release name"
    exit 1
fi

log_info "Latest cert-manager version available: $LATEST_VERSION"
log_info "Addon release name: $ADDON_RELEASE_NAME"
echo ""

# Step 5: Generate data values file
log_step "Generating cert-manager data values file..."
DATA_VALUES_FILE="cert-manager-data-values.yaml"

if ! vcf addon available get cert-manager -v "$LATEST_VERSION" -o "$DATA_VALUES_FILE" &>/dev/null; then
    log_error "Failed to generate data values file for version: $LATEST_VERSION"
    exit 1
fi

log_info "Data values file created: $DATA_VALUES_FILE"
echo ""

# Step 6: Switch to VKS cluster context
log_step "Switching to VKS cluster context..."
if ! vcf context use "$SUPERVISOR_CONTEXT:$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null; then
    log_error "Failed to switch to Supervisor context"
    exit 1
fi
log_info "Switched to context: $SUPERVISOR_CONTEXT:$SUPERVISOR_NAMESPACE_NAME"

echo ""

# Step 7: Install cert-manager addon
log_step "Installing cert-manager addon..."
log_info "This may take a few minutes..."
echo ""

if vcf addon install create cert-manager \
    --cluster-name "$CLUSTER_NAME" \
    -n "$SUPERVISOR_NAMESPACE_NAME" \
    --addon-release-name "$ADDON_RELEASE_NAME" \
    --values-config-file "$DATA_VALUES_FILE" \
    -y 2>&1 | tee /tmp/cert-manager-install.log; then
    
    log_info "Cert-manager installation initiated"
else
    log_error "Failed to initiate cert-manager installation"
    exit 1
fi

echo ""

# Step 8: Monitor installation progress
log_step "Monitoring cert-manager installation..."
INSTALLATION_TIMEOUT=300  # 5 minutes
POLL_INTERVAL=5
ELAPSED=0
READY=false

log_info "Waiting for cert-manager addon to be ready (timeout: ${INSTALLATION_TIMEOUT}s)..."
echo ""

while [[ $ELAPSED -lt $INSTALLATION_TIMEOUT ]]; do
    # Check addon installation status
    ADDON_STATUS=$(vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep cert-manager || echo "")
    
    if [[ -z "$ADDON_STATUS" ]]; then
        echo "[$(date '+%H:%M:%S')] Waiting for addon to be installed... | Elapsed: ${ELAPSED}s"
        sleep $POLL_INTERVAL
        ((ELAPSED += POLL_INTERVAL))
        continue
    fi
    
    # Extract READY status from addon list output
    ADDON_READY=$(echo "$ADDON_STATUS" | awk '{print $5}')
    
    if [[ "$ADDON_READY" == "True" ]]; then
        READY=true
        break
    fi
    
    echo "[$(date '+%H:%M:%S')] Installation in progress... | Elapsed: ${ELAPSED}s"
    
    sleep $POLL_INTERVAL
    ((ELAPSED += POLL_INTERVAL))
done

echo ""

if [[ "$READY" == "true" ]]; then
    log_info "Cert-manager addon is ready!"
    echo ""
    log_step "Addon installation status:"
    vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" | grep cert-manager
    echo ""
    
    # Step 9: Verify cert-manager in the cluster
    log_step "Verifying cert-manager pods in the cluster..."
    
    # Switch to VKS cluster context
    if ! vcf context use "$CLUSTER_CONTEXT:$CLUSTER_NAME" 2>/dev/null; then
        log_warn "Could not switch to VKS cluster context for verification"
        log_warn "You can manually verify with: kubectl get all -n cert-manager"
    else
        echo ""
        CERT_MANAGER_PODS=$(kubectl get pods -n cert-manager 2>/dev/null || echo "")
        
        if [[ ! -z "$CERT_MANAGER_PODS" ]]; then
            log_step "Cert-manager pods:"
            kubectl get pods -n cert-manager
            echo ""
            log_info "Cert-manager has been successfully installed!"
        else
            log_warn "Could not verify cert-manager pods"
        fi
    fi
else
    log_warn "Cert-manager installation timeout after $INSTALLATION_TIMEOUT seconds"
    echo ""
    log_step "Current addon status:"
    vcf addon install list --cluster-name "$CLUSTER_NAME" -n "$SUPERVISOR_NAMESPACE_NAME" | grep cert-manager || echo "No cert-manager addon found"
    echo ""
    log_warn "Installation may still be in progress. Check status later with:"
    echo "  vcf addon install list --cluster-name $CLUSTER_NAME -n $SUPERVISOR_NAMESPACE_NAME"
fi

echo ""
log_info "Cleanup: Data values file saved as: $DATA_VALUES_FILE"
log_info "You can delete it with: rm $DATA_VALUES_FILE"
