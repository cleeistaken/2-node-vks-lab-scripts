#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

log_info "Checking Supervisor Namespace Configuration: $SUPERVISOR_NAMESPACE_NAME"
echo ""

# Step 1: Verify Supervisor context
log_step "Verifying Supervisor context..."
if ! kubectl get ns &>/dev/null; then
    log_error "Not connected to Supervisor. Please run './ns1-login' first."
    exit 1
fi
log_info "Supervisor context verified"
echo ""

# Step 2: Check if namespace exists
log_step "Checking namespace existence..."
if ! kubectl get namespace "$SUPERVISOR_NAMESPACE_NAME" &>/dev/null; then
    log_error "Supervisor namespace '$SUPERVISOR_NAMESPACE_NAME' not found"
    log_info "The namespace must be created through vSphere UI or VCF CLI"
    exit 1
fi
log_info "Namespace exists: $SUPERVISOR_NAMESPACE_NAME"
echo ""

# Step 3: Check storage classes available in namespace
log_step "Checking storage classes..."
STORAGE_CLASSES=$(kubectl get sc 2>/dev/null | awk 'NR>1 {print $1}' | sort)

if [[ -z "$STORAGE_CLASSES" ]]; then
    log_warn "No storage classes found in cluster"
else
    log_info "Available storage classes:"
    kubectl get sc
    echo ""
    
    # Check if configured storage class exists
    if echo "$STORAGE_CLASSES" | grep -q "^${CLUSTER_STORAGE_CLASS}$"; then
        log_info "✓ Configured storage class found: $CLUSTER_STORAGE_CLASS"
    else
        log_warn "⚠ Configured storage class NOT found: $CLUSTER_STORAGE_CLASS"
        log_warn "Available classes: $STORAGE_CLASSES"
    fi
fi
echo ""

# Step 4: Check VM classes available in namespace
log_step "Checking VM classes (VirtualMachineClasses)..."
VM_CLASSES=$(kubectl get virtualmachineclasses -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null || echo "")

if [[ -z "$VM_CLASSES" ]]; then
    log_warn "No VM classes found in namespace"
    log_info "This is normal - VM classes are typically cluster-wide"
else
    log_info "VM classes in namespace:"
    kubectl get virtualmachineclasses -n "$SUPERVISOR_NAMESPACE_NAME"
    echo ""
fi

# Check cluster-wide VM classes
log_step "Checking cluster-wide VM classes..."
CLUSTER_WIDE_VMS=$(kubectl get virtualmachineclasses 2>/dev/null || echo "")

if [[ -z "$CLUSTER_WIDE_VMS" ]]; then
    log_warn "No VM classes found cluster-wide"
else
    log_info "Available VM classes:"
    kubectl get virtualmachineclasses
    echo ""
    
    # Check if configured VM classes exist
    if kubectl get virtualmachineclass "$CLUSTER_VM_CLASS_CONTROL_PLANE" &>/dev/null; then
        log_info "✓ Control plane VM class found: $CLUSTER_VM_CLASS_CONTROL_PLANE"
    else
        log_warn "⚠ Control plane VM class NOT found: $CLUSTER_VM_CLASS_CONTROL_PLANE"
    fi
    
    if kubectl get virtualmachineclass "$CLUSTER_VM_CLASS_WORKER" &>/dev/null; then
        log_info "✓ Worker VM class found: $CLUSTER_VM_CLASS_WORKER"
    else
        log_warn "⚠ Worker VM class NOT found: $CLUSTER_VM_CLASS_WORKER"
    fi
fi
echo ""

# Step 5: Check namespace labels and annotations
log_step "Checking namespace labels and annotations..."
NAMESPACE_INFO=$(kubectl get namespace "$SUPERVISOR_NAMESPACE_NAME" -o yaml)

if echo "$NAMESPACE_INFO" | grep -q "vmware-system-namespace"; then
    log_info "✓ Namespace is a VMware system namespace"
else
    log_info "Namespace labels and annotations:"
    kubectl get namespace "$SUPERVISOR_NAMESPACE_NAME" -o yaml | grep -A 10 "metadata:" | grep -E "labels:|annotations:" -A 5
fi
echo ""

# Step 6: Check content library configuration (optional)
log_step "Checking for content library configuration..."
CONTENT_LIBS=$(kubectl get configmap -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null | grep -i "library\|content" || echo "")

if [[ -z "$CONTENT_LIBS" ]]; then
    log_info "No content library config maps found (this is optional)"
else
    log_info "Content library configurations:"
    echo "$CONTENT_LIBS"
fi
echo ""

# Step 7: Check network policies
log_step "Checking network policies..."
NET_POLICIES=$(kubectl get networkpolicies -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null || echo "")

if [[ -z "$NET_POLICIES" ]]; then
    log_info "No network policies defined (this is optional)"
else
    log_info "Network policies:"
    kubectl get networkpolicies -n "$SUPERVISOR_NAMESPACE_NAME"
fi
echo ""

# Step 8: Check RBAC (Roles and RoleBindings)
log_step "Checking RBAC configuration..."
ROLES=$(kubectl get roles -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null || echo "")
ROLEBINDINGS=$(kubectl get rolebindings -n "$SUPERVISOR_NAMESPACE_NAME" 2>/dev/null || echo "")

if [[ -z "$ROLES" && -z "$ROLEBINDINGS" ]]; then
    log_info "No custom RBAC roles defined in namespace"
else
    if [[ ! -z "$ROLES" ]]; then
        log_info "Roles:"
        kubectl get roles -n "$SUPERVISOR_NAMESPACE_NAME"
    fi
    
    if [[ ! -z "$ROLEBINDINGS" ]]; then
        log_info "RoleBindings:"
        kubectl get rolebindings -n "$SUPERVISOR_NAMESPACE_NAME"
    fi
fi
echo ""

# Step 9: Summary
log_step "Configuration Summary"
echo ""
echo "Namespace Configuration for: $SUPERVISOR_NAMESPACE_NAME"
echo "=============================================="
echo "Storage Class (configured):   $CLUSTER_STORAGE_CLASS"
echo "Control Plane VM Class:       $CLUSTER_VM_CLASS_CONTROL_PLANE"
echo "Worker VM Class:              $CLUSTER_VM_CLASS_WORKER"
echo ""

# Final readiness check
log_step "Namespace Readiness Status"
echo ""

if [[ -z "$STORAGE_CLASSES" ]]; then
    log_warn "⚠ No storage classes available - cannot create clusters"
    READY=0
else
    if echo "$STORAGE_CLASSES" | grep -q "^${CLUSTER_STORAGE_CLASS}$"; then
        log_info "✓ Storage class configured and available"
    else
        log_warn "⚠ Storage class not available: $CLUSTER_STORAGE_CLASS"
        READY=0
    fi
fi

if [[ ! -z "$CLUSTER_WIDE_VMS" ]]; then
    if kubectl get virtualmachineclass "$CLUSTER_VM_CLASS_CONTROL_PLANE" &>/dev/null && \
       kubectl get virtualmachineclass "$CLUSTER_VM_CLASS_WORKER" &>/dev/null; then
        log_info "✓ VM classes available"
    else
        log_warn "⚠ One or more VM classes not available"
    fi
else
    log_warn "⚠ No VM classes found"
fi

echo ""
log_info "Namespace check complete"
echo ""
log_info "To create a VKS cluster in this namespace, run:"
echo "  ./ns1-create-vks1-1.35"
