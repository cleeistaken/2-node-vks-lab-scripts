#!/bin/bash

set -euo pipefail

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/vks-lab.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Verify we're logged into the Supervisor
verify_supervisor_context() {
    if ! kubectl get ns &>/dev/null; then
        log_error "Not connected to Supervisor. Please run 'login-ns1' first."
        exit 1
    fi
}

# Create VKS cluster manifest
create_vks_manifest() {
    local manifest_file="$1"
    
    cat > "$manifest_file" <<EOL
apiVersion: cluster.x-k8s.io/v1beta2
kind: Cluster
metadata:
  name: $CLUSTER_NAME
spec:
  clusterNetwork:
    services:
      cidrBlocks: ["$CLUSTER_SERVICES_CIDR"]
    pods:
      cidrBlocks: ["$CLUSTER_PODS_CIDR"]
    serviceDomain: "$CLUSTER_SERVICE_DOMAIN"
  topology:
    classRef:
      name: builtin-generic-v3.6.0
    version: $CLUSTER_KUBERNETES_VERSION
    controlPlane:
      replicas: $CLUSTER_CONTROL_PLANE_REPLICAS
    workers:
      machineDeployments:
      - class: node-pool
        name: node-pool-1
        replicas: $CLUSTER_WORKER_REPLICAS
        variables:
          overrides:
          - name: vmClass
            value: $CLUSTER_VM_CLASS_WORKER
          - name: volumes
            value:
            - capacity: $STORAGE_SIZE
              mountPath: $STORAGE_MOUNT_PATH
              name: containerd
              storageClass: $CLUSTER_STORAGE_CLASS
    variables:
    - name: vmClass
      value: $CLUSTER_VM_CLASS_CONTROL_PLANE
    - name: storageClass
      value: $CLUSTER_STORAGE_CLASS
    - name: vsphereOptions
      value:
        persistentVolumes:
          defaultStorageClass: $CLUSTER_STORAGE_CLASS
    - name: kubernetes
      value:
        security:
          podSecurityStandard:
            enforce: baseline
EOL
}

log_info "Creating VKS Cluster: $CLUSTER_NAME"
echo ""

# Step 1: Verify we're in the right context
log_step "Verifying Supervisor context..."
verify_supervisor_context
log_info "Supervisor context verified"

echo ""

# Step 2: Create the manifest
log_step "Creating VKS cluster manifest file..."
MANIFEST_FILE="vks.yaml"
create_vks_manifest "$MANIFEST_FILE"
log_info "Manifest created: $MANIFEST_FILE"

# Show manifest summary
log_info "Manifest configuration:"
echo "  - Cluster Name: $CLUSTER_NAME"
echo "  - Kubernetes Version: $CLUSTER_KUBERNETES_VERSION"
echo "  - Control Plane Replicas: $CLUSTER_CONTROL_PLANE_REPLICAS"
echo "  - Worker Replicas: $CLUSTER_WORKER_REPLICAS"
echo "  - Worker VM Class: $CLUSTER_VM_CLASS_WORKER"
echo "  - Storage Class: $CLUSTER_STORAGE_CLASS"

echo ""

# Step 3: Apply the manifest
log_step "Applying VKS cluster manifest..."
if kubectl apply -f "$MANIFEST_FILE"; then
    log_info "VKS cluster manifest applied successfully"
else
    log_error "Failed to apply VKS cluster manifest"
    exit 1
fi

echo ""

# Step 4: Monitor cluster creation
log_step "Monitoring VKS cluster creation..."

# Cluster creation monitoring with timeout
CREATION_TIMEOUT=${CLUSTER_CREATION_TIMEOUT:-900}  # Default 15 minutes
POLL_INTERVAL=5  # Check every 5 seconds
ELAPSED=0
READY=false

log_info "Timeout: $CREATION_TIMEOUT seconds (~$((CREATION_TIMEOUT/60)) minutes)"
echo ""

while [[ $ELAPSED -lt $CREATION_TIMEOUT ]]; do
    # Get cluster status using kubectl get clusters
    CLUSTER_STATUS=$(kubectl get clusters "$CLUSTER_NAME" 2>/dev/null)
    
    if [[ -z "$CLUSTER_STATUS" ]]; then
        echo "[$(date '+%H:%M:%S')] Waiting for cluster to be created..."
        sleep $POLL_INTERVAL
        ((ELAPSED += POLL_INTERVAL))
        continue
    fi
    
    # Extract AVAILABLE status from the kubectl output
    # The AVAILABLE column is a boolean True/False value
    AVAILABLE_STATUS=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $3}')
    PHASE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $9}')
    CP_AVAILABLE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $5}')
    W_AVAILABLE=$(echo "$CLUSTER_STATUS" | awk 'NR==2 {print $7}')
    
    # Check if cluster is available
    if [[ "$AVAILABLE_STATUS" == "True" ]]; then
        READY=true
        break
    fi
    
    # Print status if still creating
    echo "[$(date '+%H:%M:%S')] AVAILABLE: $AVAILABLE_STATUS | Phase: $PHASE | CP: $CP_AVAILABLE | Workers: $W_AVAILABLE | Elapsed: ${ELAPSED}s"
    
    # Wait before next check
    sleep $POLL_INTERVAL
    ((ELAPSED += POLL_INTERVAL))
done

echo ""

if [[ "$READY" == "true" ]]; then
    log_info "VKS Cluster is Ready: $CLUSTER_NAME"
    echo ""
    log_step "Final cluster status:"
    kubectl get clusters "$CLUSTER_NAME"
    echo ""
    log_info "You can now access the cluster with: ./login-vks1"
else
    log_warn "VKS cluster creation timeout after $CREATION_TIMEOUT seconds"
    echo ""
    log_step "Current cluster status:"
    kubectl get clusters "$CLUSTER_NAME"
    echo ""
    log_info "To check status later, run: kubectl get clusters $CLUSTER_NAME"
    log_info "To view cluster details, run: kubectl describe cluster $CLUSTER_NAME"
    log_info "To check full status, run: kubectl get cluster $CLUSTER_NAME -o yaml"
fi
